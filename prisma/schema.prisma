generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "linux-musl"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String           @unique
  password        String
  phoneNumber     String?
  role            Role             @default(RESTAURANT_OWNER)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  adminLogs       AdminLog[]       @relation("AdminActions")
  customerProfile CustomerProfile?
  restaurant      Restaurant?
}

model Restaurant {
  id                String            @id @default(cuid())
  name              String
  description       String?
  logo              String?
  address           String?
  phoneNumber       String?
  email             String?
  website           String?
  openingHours      Json?
  socialMedia       Json?
  termsConditions   String?
  howToUse          String?
  revenueSettings   Json?
  theme             Json?
  backgroundPattern String?
  appName           String            @unique
  urlSlug           String            @unique
  qrCode            String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  ownerId           String            @unique
  accountStatus     AccountStatus     @default(PENDING)
  suspendedAt       DateTime?
  suspendedReason   String?
  activatedAt       DateTime?
  lastLoginAt       DateTime?
  adminNotes        String?
  customers         CustomerProfile[]
  loyaltyProgram    LoyaltyProgram?
  owner             User              @relation(fields: [ownerId], references: [id])
  stats             RestaurantStats?
  subscription      Subscription?
    googleMapsUrl String?
     
  facebookUrl   String?
  instagramUrl  String?
  twitterUrl    String?
}

model LoyaltyProgram {
  id                    String     @id @default(cuid())
  spendThreshold        Float      @default(1)
  pointsEarned          Int        @default(1)
  autoPushNotifications Boolean    @default(true)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  restaurantId          String     @unique
  restaurant            Restaurant @relation(fields: [restaurantId], references: [id])
  rewards               Reward[]
}

model CustomerProfile {
  id            String         @id @default(cuid())
  name          String
  customerId    String         @unique
  points        Int            @default(0)
  stamps        Int            @default(0)
  createdAt     DateTime       @default(now())
  lastVisit     DateTime?
  userId        String         @unique
  restaurantId  String
  restaurant    Restaurant     @relation(fields: [restaurantId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  earnedRewards EarnedReward[]
  visits        Visit[]
    hasClaimedReviewBonus Boolean @default(false)
      hasClaimedGoogleMapsBonus Boolean @default(false)
  hasClaimedFacebookBonus   Boolean @default(false)
  hasClaimedInstagramBonus  Boolean @default(false)
  hasClaimedTwitterBonus    Boolean @default(false)
}

model Visit {
  id           String          @id @default(cuid())
  date         DateTime        @default(now())
  amount       Float?
  pointsEarned Int             @default(0)
  stampsEarned Int             @default(0)
  customerId   String
  customer     CustomerProfile @relation(fields: [customerId], references: [id])
}

model Reward {
  id               String         @id @default(cuid())
  name             String
  pointsRequired   Int
  description      String?
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  loyaltyProgramId String
  earnedRewards    EarnedReward[]
  loyaltyProgram   LoyaltyProgram @relation(fields: [loyaltyProgramId], references: [id])
}

model EarnedReward {
  id         String          @id @default(cuid())
  rewardId   String
  earnedAt   DateTime        @default(now())
  usedAt     DateTime?
  expiresAt  DateTime?
  customerId String
  customer   CustomerProfile @relation(fields: [customerId], references: [id])
  reward     Reward          @relation(fields: [rewardId], references: [id])
}

model Subscription {
  id            String           @id @default(cuid())
  plan          SubscriptionPlan @default(FREE)
  startDate     DateTime         @default(now())
  endDate       DateTime?
  autoRenew     Boolean          @default(true)
  price         Float?
  paymentMethod String?
  restaurantId  String           @unique
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  restaurant    Restaurant       @relation(fields: [restaurantId], references: [id])
}

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String?
  action     String
  targetType String
  targetId   String
  details    Json?
  createdAt  DateTime @default(now())
  admin      User?    @relation("AdminActions", fields: [adminId], references: [id])
}

model RestaurantStats {
  id              String     @id @default(cuid())
  restaurantId    String     @unique
  totalCustomers  Int        @default(0)
  activeCustomers Int        @default(0)
  totalVisits     Int        @default(0)
  totalPoints     Int        @default(0)
  totalRewards    Int        @default(0)
  totalRevenue    Float?     @default(0)
  lastUpdated     DateTime   @default(now())
  monthlyStats    Json?
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id])
}

enum Role {
  RESTAURANT_OWNER
  CUSTOMER
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum SubscriptionPlan {
  FREE
  BASIC
  PREMIUM
  ENTERPRISE
}
